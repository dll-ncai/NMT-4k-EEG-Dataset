@(
    "* text=auto"
    ""
    "*.py text eol=lf"
    "*.ipynb text eol=lf"
    "*.md text eol=lf"
    "*.txt text eol=lf"
    "*.csv text eol=lf"
    "*.tsv text eol=lf"
    "*.json text eol=lf"
    "*.yml text eol=lf"
    "*.yaml text eol=lf"
    ""
    "*.png binary"
    "*.jpg binary"
    "*.jpeg binary"
    "*.gif binary"
    "*.pdf binary"
    "*.zip binary"
) | Set-Content -Encoding ascii .gitattributes